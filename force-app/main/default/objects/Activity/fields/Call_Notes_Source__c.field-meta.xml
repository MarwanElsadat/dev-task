<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Call_Notes_Source__c</fullName>
    <description
  >Tracks where the Task originated. Used to filter call notes that came through the Call Notes Logger LWC vs. legacy/manual Tasks.</description>
    <inlineHelpText>Set automatically by the Call Notes Logger.</inlineHelpText>
    <label>Call Notes Source</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Call Notes Logger</fullName>
                <default>false</default>
                <label>Call Notes Logger</label>
            </value>
            <value>
                <fullName>Other</fullName>
                <default>true</default>
                <label>Other</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
